class _CourierData {
  const _CourierData({
    required this.name,
    required this.status,
    required this.orders,
    required this.lat,
    required this.lng,
    required this.color,
  });
  final String name;
  final String status;
  final int orders;
  final double lat;
  final double lng;
  final Color color;
}

class _OrderData {
  const _OrderData({
    required this.id,
    required this.customer,
    required this.address,
    required this.status,
    required this.courier,
    required this.eta,
    required this.statusColor,
  });
  final String id;
  final String customer;
  final String address;
  final String status;
  final String courier;
  final String eta;
  final Color statusColor;
}


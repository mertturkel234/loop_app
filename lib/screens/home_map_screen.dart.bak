}

// ─────────────────────────────────────────────────────────────────────────────
// Etkileşimli harita kanvası (InteractiveViewer ile pan/zoom)
// ─────────────────────────────────────────────────────────────────────────────

class _MapCanvas extends StatefulWidget {
  const _MapCanvas({required this.couriers, required this.pulseAnim});
  final List<_CourierData> couriers;
  final Animation<double> pulseAnim;

  @override
  State<_MapCanvas> createState() => _MapCanvasState();
}

class _MapCanvasState extends State<_MapCanvas> {
  final _transformCtrl = TransformationController();

  @override
  void dispose() {
    _transformCtrl.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Padding(
      padding: const EdgeInsets.fromLTRB(20, 12, 20, 0),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(20),
        child: Container(
          decoration: BoxDecoration(
            color: const Color(0xFF06101C),
            borderRadius: BorderRadius.circular(20),
            border: Border.all(color: AppColors.cardBorder, width: 1),
            boxShadow: [
              BoxShadow(
                  color: Colors.black.withAlpha(80),
                  blurRadius: 20,
                  offset: const Offset(0, 6)),
            ],
          ),
          child: Stack(
            children: [
              // ── Kaydırılabilir & zum yapılabilir harita ──────────────────
              InteractiveViewer(
                transformationController: _transformCtrl,
                minScale: 0.8,
                maxScale: 3.5,
                boundaryMargin: const EdgeInsets.all(80),
                child: SizedBox(
                  width: 900,
                  height: 900,
                  child: Stack(
                    children: [
                      // Harita zemini + yol ağı
                      Positioned.fill(
                          child: CustomPaint(painter: _RichMapPainter())),
                      // Kurye noktaları (harita koordinatlarında)
                      ...widget.couriers.map((c) => _CourierDot(
                            courier: c,
                            pulseAnim: widget.pulseAnim,
                          )),
                    ],
                  ),
                ),
              ),

              // ── Harita kontrol butonları (overlay) ───────────────────────
              Positioned(
                right: 12,
                bottom: 12,
                child: Column(
                  children: [
                    _MapBtn(
                      icon: Icons.add_rounded,
                      onTap: () {
                        final current = _transformCtrl.value;
                        _transformCtrl.value = current.clone()
                          ..scale(1.25);
                      },
                    ),
                    const SizedBox(height: 6),
                    _MapBtn(
                      icon: Icons.remove_rounded,
                      onTap: () {
                        final current = _transformCtrl.value;
                        _transformCtrl.value = current.clone()
                          ..scale(0.8);
                      },
                    ),
                    const SizedBox(height: 6),
                    _MapBtn(
                      icon: Icons.my_location_rounded,
                      color: AppColors.textAccent,
                      onTap: () => _transformCtrl.value = Matrix4.identity(),
                    ),
                  ],
                ),
              ),

              // ── Sol üst overlay bilgisi ───────────────────────────────────
              Positioned(
                left: 12,
                top: 12,
                child: Container(
                  padding: const EdgeInsets.symmetric(
                      horizontal: 10, vertical: 6),
                  decoration: BoxDecoration(
                    color: const Color(0xFF060D1A).withAlpha(200),
                    borderRadius: BorderRadius.circular(8),
                    border: Border.all(
                        color: AppColors.cardBorder, width: 1),
                  ),
                  child: Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      Container(
                          width: 6, height: 6,
                          decoration: const BoxDecoration(
                              color: AppColors.textAccent,
                              shape: BoxShape.circle)),
                      const SizedBox(width: 6),
                      Text('Canlı',
                          style: GoogleFonts.barlow(
                              fontSize: 11,
                              fontWeight: FontWeight.w600,
                              color: AppColors.textAccent)),
                      const SizedBox(width: 4),
                      Text('İstanbul',
                          style: GoogleFonts.barlow(
                              fontSize: 11,
                              color: AppColors.textSecondary)),
                    ],
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}

class _MapBtn extends StatelessWidget {
  const _MapBtn({required this.icon, this.color, this.onTap});
  final IconData icon;
  final Color? color;
  final VoidCallback? onTap;

  @override
  Widget build(BuildContext context) {
    return GestureDetector(
      onTap: onTap,
      child: Container(
        width: 34,
        height: 34,
        decoration: BoxDecoration(
          color: const Color(0xFF0F1C2E),
          borderRadius: BorderRadius.circular(8),
          border: Border.all(color: AppColors.cardBorder, width: 1),
          boxShadow: [
            BoxShadow(
                color: Colors.black.withAlpha(60), blurRadius: 8)
          ],
        ),
        child: Icon(icon, size: 16,
            color: color ?? AppColors.textSecondary),
      ),
    );
  }
}

/// Zengin karanlık harita çizici — yol ağı, mahalleler, parklar.
class _RichMapPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final w = size.width;
    final h = size.height;

    // ── Zemin rengi (koyu lacivert) ──────────────────────────────────────
    canvas.drawRect(Rect.fromLTWH(0, 0, w, h),
        Paint()..color = const Color(0xFF06101C));

    // ── Su yüzeyleri (koyu mavi dikdörtgenler) ───────────────────────────
    _drawRect(canvas, w * 0.0, h * 0.35, w * 0.18, h * 0.12,
        const Color(0xFF071420));
    _drawRect(canvas, w * 0.72, h * 0.60, w * 0.28, h * 0.18,
        const Color(0xFF071420));

    // ── Mahalle blokları ─────────────────────────────────────────────────
    final blockPaint = Paint()..color = const Color(0xFF0C1A2A);
    for (final b in _blocks(w, h)) {
      canvas.drawRRect(
          RRect.fromRectAndRadius(b, const Radius.circular(4)), blockPaint);
    }

    // ── Parklar (koyu yeşil) ─────────────────────────────────────────────
    final parkPaint = Paint()..color = const Color(0xFF0B1F12);
    _drawRect(canvas, w * 0.42, h * 0.18, w * 0.08, h * 0.06, parkPaint.color);
    _drawRect(canvas, w * 0.65, h * 0.40, w * 0.06, h * 0.05, parkPaint.color);

    // ── Arka plan grid ───────────────────────────────────────────────────
    final gridPaint = Paint()
      ..color = const Color(0xFF112033).withAlpha(50)
      ..strokeWidth = 0.5;
    const step = 40.0;
    for (double x = 0; x <= w; x += step) {
      canvas.drawLine(Offset(x, 0), Offset(x, h), gridPaint);
    }
    for (double y = 0; y <= h; y += step) {
      canvas.drawLine(Offset(0, y), Offset(w, y), gridPaint);
    }

    // ── Ana arterler (geniş, parlak) ─────────────────────────────────────
    final arterPaint = Paint()
      ..color = const Color(0xFF1E3A60)
      ..strokeWidth = 7
      ..strokeCap = StrokeCap.round;
    // E-5 benzeri yatay
    canvas.drawLine(Offset(0, h * 0.30), Offset(w, h * 0.30), arterPaint);
    canvas.drawLine(Offset(0, h * 0.62), Offset(w, h * 0.62), arterPaint);
    // Dikey ana yollar
    canvas.drawLine(Offset(w * 0.25, 0), Offset(w * 0.25, h), arterPaint);
    canvas.drawLine(Offset(w * 0.60, 0), Offset(w * 0.60, h), arterPaint);

    // ── Ara sokaklar ─────────────────────────────────────────────────────
    final roadPaint = Paint()
      ..color = const Color(0xFF152A44)
      ..strokeWidth = 3
      ..strokeCap = StrokeCap.round;
    final roads = [
      [Offset(0, h * 0.15), Offset(w * 0.60, h * 0.15)],
      [Offset(w * 0.25, h * 0.15), Offset(w * 0.60, h * 0.30)],
      [Offset(0, h * 0.47), Offset(w, h * 0.47)],
      [Offset(0, h * 0.78), Offset(w, h * 0.78)],
      [Offset(w * 0.12, 0), Offset(w * 0.12, h * 0.30)],
      [Offset(w * 0.42, 0), Offset(w * 0.42, h)],
      [Offset(w * 0.80, 0), Offset(w * 0.80, h * 0.62)],
      [Offset(w * 0.25, h * 0.62), Offset(w * 0.42, h * 0.78)],
      [Offset(w * 0.60, h * 0.47), Offset(w * 0.80, h * 0.62)],
    ];
    for (final r in roads) {
      canvas.drawLine(r[0], r[1], roadPaint);
    }

    // ── Kavşak noktaları ─────────────────────────────────────────────────
    final nodePaint = Paint()..color = const Color(0xFF1E3A60);
    for (final p in _intersections(w, h)) {
      canvas.drawCircle(p, 5, nodePaint);
    }

    // ── Mahalle isimleri ─────────────────────────────────────────────────
    _drawLabel(canvas, 'BAĞCILAR', Offset(w * 0.12, h * 0.38));
    _drawLabel(canvas, 'GÜNGÖREN', Offset(w * 0.35, h * 0.20));
    _drawLabel(canvas, 'BAŞAKŞEHİR', Offset(w * 0.55, h * 0.12));
    _drawLabel(canvas, 'ESENLER', Offset(w * 0.70, h * 0.38));
    _drawLabel(canvas, 'ŞİŞLİ', Offset(w * 0.18, h * 0.72));
    _drawLabel(canvas, 'BEŞIKTAŞ', Offset(w * 0.52, h * 0.72));
    _drawLabel(canvas, 'KADIKÖY', Offset(w * 0.78, h * 0.80));
  }

  List<Rect> _blocks(double w, double h) {
    const defs = [
      [0.02, 0.03, 0.10, 0.10],
      [0.14, 0.03, 0.09, 0.10],
      [0.02, 0.17, 0.08, 0.10],
      [0.30, 0.03, 0.10, 0.09],
      [0.30, 0.32, 0.10, 0.12],
      [0.44, 0.32, 0.14, 0.12],
      [0.62, 0.03, 0.16, 0.09],
      [0.62, 0.32, 0.16, 0.10],
      [0.83, 0.03, 0.14, 0.09],
      [0.83, 0.32, 0.14, 0.10],
      [0.02, 0.65, 0.10, 0.11],
      [0.14, 0.65, 0.10, 0.11],
      [0.44, 0.65, 0.14, 0.11],
      [0.62, 0.65, 0.16, 0.11],
      [0.83, 0.65, 0.14, 0.11],
      [0.02, 0.80, 0.21, 0.17],
      [0.27, 0.80, 0.13, 0.17],
      [0.44, 0.80, 0.14, 0.17],
      [0.62, 0.80, 0.16, 0.17],
      [0.83, 0.80, 0.14, 0.17],
    ];
    return defs
        .map((d) => Rect.fromLTWH(
            w * d[0], h * d[1], w * d[2], h * d[3]))
        .toList();
  }

  List<Offset> _intersections(double w, double h) => [
        Offset(w * 0.25, h * 0.30),
        Offset(w * 0.60, h * 0.30),
        Offset(w * 0.25, h * 0.62),
        Offset(w * 0.60, h * 0.62),
        Offset(w * 0.42, h * 0.47),
        Offset(w * 0.80, h * 0.47),
        Offset(w * 0.42, h * 0.30),
        Offset(w * 0.80, h * 0.30),
      ];

  void _drawRect(Canvas canvas, double x, double y,
      double width, double height, Color color) {
    canvas.drawRRect(
        RRect.fromRectAndRadius(
            Rect.fromLTWH(x, y, width, height),
            const Radius.circular(3)),
        Paint()..color = color);
  }

  void _drawLabel(Canvas canvas, String text, Offset pos) {
    final tp = TextPainter(
      text: TextSpan(
        text: text,
        style: const TextStyle(
          color: Color(0xFF1A3A5A),
          fontSize: 9,
          fontWeight: FontWeight.w600,
          letterSpacing: 0.8,
        ),
      ),
      textDirection: TextDirection.ltr,
    )..layout();
    tp.paint(canvas, pos - Offset(tp.width / 2, tp.height / 2));
  }

  @override
  bool shouldRepaint(_RichMapPainter old) => false;
}



// Kurye noktası
class _CourierDot extends StatelessWidget {
  const _CourierDot({required this.courier, required this.pulseAnim});
  final _CourierData courier;
  final Animation<double> pulseAnim;

  @override
  Widget build(BuildContext context) {
    return LayoutBuilder(builder: (_, c) {
      final x = c.maxWidth * courier.lng;
      final y = c.maxHeight * courier.lat;
      return Positioned(
        left: x - 20,
        top: y - 20,
        child: AnimatedBuilder(
          animation: pulseAnim,
          builder: (_, child) => Stack(
            alignment: Alignment.center,
            children: [
              // Hale
              Container(
                width: 40 * pulseAnim.value,
                height: 40 * pulseAnim.value,
                decoration: BoxDecoration(
                  shape: BoxShape.circle,
                  color:
                      courier.color.withAlpha((40 * pulseAnim.value).toInt()),
                ),
              ),
              // İkon
              Container(
                width: 26,
                height: 26,
                decoration: BoxDecoration(
                  color: courier.color,
                  shape: BoxShape.circle,
                  boxShadow: [
                    BoxShadow(
                        color: courier.color.withAlpha(100),
                        blurRadius: 8)
                  ],
                ),
                child: const Icon(Icons.directions_bike_rounded,
                    size: 14, color: Colors.white),
              ),
            ],
          ),
        ),
      );
    });
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// Aktif sipariş listesi
// ─────────────────────────────────────────────────────────────────────────────

class _ActiveOrdersList extends StatelessWidget {
  const _ActiveOrdersList({required this.orders});
  final List<_OrderData> orders;

  @override
  Widget build(BuildContext context) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Padding(
          padding: const EdgeInsets.fromLTRB(20, 16, 20, 10),
          child: Row(
            children: [
              Text('Aktif Siparişler',
                  style: GoogleFonts.barlow(
                      fontSize: 14,
                      fontWeight: FontWeight.w700,
                      color: AppColors.textPrimary)),
              const SizedBox(width: 8),
              Container(
                padding:
                    const EdgeInsets.symmetric(horizontal: 8, vertical: 2),
                decoration: BoxDecoration(
                  color: AppColors.textAccent.withAlpha(20),
                  borderRadius: BorderRadius.circular(10),
                ),
                child: Text('${orders.length}',
                    style: GoogleFonts.barlow(
                        fontSize: 11,
                        fontWeight: FontWeight.w700,
                        color: AppColors.textAccent)),
              ),
            ],
          ),
        ),
        Expanded(
          child: ListView.separated(
            padding: const EdgeInsets.fromLTRB(20, 0, 20, 12),
            itemCount: orders.length,
            separatorBuilder: (_, idx) => const SizedBox(height: 8),
            itemBuilder: (_, i) => _ActiveOrderCard(order: orders[i]),
          ),
        ),
      ],
    );
  }
}

class _ActiveOrderCard extends StatelessWidget {
  const _ActiveOrderCard({required this.order});
  final _OrderData order;

  @override
  Widget build(BuildContext context) {
    return Container(
      padding: const EdgeInsets.all(14),
      decoration: BoxDecoration(
        color: AppColors.cardBackground,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: AppColors.cardBorder, width: 1),
      ),
      child: Row(
        children: [
          // Durum göstergesi
          Container(
            width: 4, height: 42,
            decoration: BoxDecoration(
              color: order.statusColor,
              borderRadius: BorderRadius.circular(2),
            ),
          ),
          const SizedBox(width: 12),
          // Bilgiler
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Text(order.id,
                        style: GoogleFonts.barlow(
                            fontSize: 12,
                            fontWeight: FontWeight.w700,
                            color: order.statusColor)),
                    const Spacer(),
                    Container(
                      padding: const EdgeInsets.symmetric(
                          horizontal: 8, vertical: 2),
                      decoration: BoxDecoration(
                        color: order.statusColor.withAlpha(20),
                        borderRadius: BorderRadius.circular(6),
                        border: Border.all(
                            color: order.statusColor.withAlpha(60),
                            width: 1),
                      ),
                      child: Text(order.status,
                          style: GoogleFonts.barlow(
                              fontSize: 10,
                              fontWeight: FontWeight.w600,
                              color: order.statusColor)),
                    ),
                  ],
                ),
                const SizedBox(height: 3),
                Text(order.customer,
                    style: GoogleFonts.barlow(
                        fontSize: 13,
                        fontWeight: FontWeight.w600,
                        color: AppColors.textPrimary)),
                const SizedBox(height: 2),
                Row(
                  children: [
                    const Icon(Icons.location_on_rounded,
                        size: 11, color: AppColors.textLabel),
                    const SizedBox(width: 3),
                    Expanded(
                      child: Text(order.address,
                          overflow: TextOverflow.ellipsis,
                          style: GoogleFonts.barlow(
                              fontSize: 11,
                              color: AppColors.textSecondary)),
                    ),
                    const SizedBox(width: 8),
                    const Icon(Icons.access_time_rounded,
                        size: 11, color: AppColors.textLabel),
                    const SizedBox(width: 3),
                    Text(order.eta,
                        style: GoogleFonts.barlow(
                            fontSize: 11,
                            fontWeight: FontWeight.w600,
                            color: AppColors.textPrimary)),
                  ],
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }
}


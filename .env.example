# LOOP — Environment Variables Template
# Copy to .env and fill in values. Never commit .env to version control.

# Backend API (Go service — when connected)
API_BASE_URL=http://localhost:8080
API_WEBSOCKET_URL=ws://localhost:8080/ws

# Authentication
JWT_PUBLIC_KEY=

# Maps (optional — for production tile providers)
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# AI Logistics Assistant (optional)
AI_ASSISTANT_API_KEY=
AI_ASSISTANT_MODEL=

# Feature flags
ENABLE_AI_OPTIMIZATION=true
ENABLE_LIVE_TRACKING=true
